# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Template for the .env file placed on the EC2 instance.
#
# ⚠️  NEVER commit the real .env file to version control.
#     Copy this file to .env and fill in real values before starting the stack.
#
# The CI/CD pipeline (deploy job) writes this file automatically from
# GitHub Actions secrets. This file serves as documentation only.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────────────────
DB_NAME=eduspace
DB_USER=postgres
DB_PASSWORD=changeme_strong_password


# ── RabbitMQ ───────────────────────────────────────────────────────────────
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=changeme_rabbit_password

# ── JWT ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme_jwt_secret_at_least_256_bits

# ── Image tags (managed by CI/CD — do not edit manually) ──────────────────
BACK_VERSION=latest
FRONT_VERSION=latest

# ── GitHub Container Registry owner (lowercase org or user name) ───────────
GITHUB_REPOSITORY_OWNER=your-org

