			"name": "1. Authentication",
			"item": [
				{
					"name": "1.1 Login Teacher (Success)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has message', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.message).to.eql('Login successful');",
									"});",
									"",
									"pm.test('Response has user info', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.user).to.have.property('id');",
									"    pm.expect(jsonData.user).to.have.property('name');",
									"    pm.expect(jsonData.user).to.have.property('email');",
									"    pm.expect(jsonData.user).to.have.property('role');",
									"    pm.expect(jsonData.user.role).to.eql('TEACHER');",
									"});",
									"",
									"pm.test('Headers contain tokens', function () {",
									"    pm.expect(pm.response.headers.get('X-Access-Token')).to.not.be.null;",
									"    pm.expect(pm.response.headers.get('X-Refresh-Token')).to.not.be.null;",
									"    pm.expect(pm.response.headers.get('X-Expires-In')).to.not.be.null;",
									"});",
									"",
									"// Salvar tokens para próximos testes",
									"const accessToken = pm.response.headers.get('X-Access-Token');",
									"const refreshToken = pm.response.headers.get('X-Refresh-Token');",
									"const expiresIn = pm.response.headers.get('X-Expires-In');",
									"",
									"if (accessToken) {",
									"    pm.collectionVariables.set('accessToken', accessToken);",
									"    console.log('✅ Access Token salvo:', accessToken.substring(0, 50) + '...');",
									"}",
									"",
									"if (refreshToken) {",
									"    pm.collectionVariables.set('refreshToken', refreshToken);",
									"    console.log('✅ Refresh Token salvo:', refreshToken.substring(0, 50) + '...');",
									"}",
									"",
									"if (expiresIn) {",
									"    pm.collectionVariables.set('expiresIn', expiresIn);",
									"    console.log('✅ Expires In:', expiresIn + ' segundos');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
