			"name": "2. Token Refresh",
			"item": [
				{
					"name": "2.1 Refresh Token (Success)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Verificar se temos um refresh token disponível",
									"const refreshToken = pm.collectionVariables.get('refreshToken');",
									"if (!refreshToken) {",
									"    console.log('⚠️ Refresh token não encontrado. Execute primeiro o login.');",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response message is correct', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.message).to.eql('Token refreshed successfully');",
									"});",
									"",
									"pm.test('New access token in header', function () {",
									"    pm.expect(pm.response.headers.get('X-Access-Token')).to.not.be.null;",
									"    pm.expect(pm.response.headers.get('X-Expires-In')).to.not.be.null;",
									"});",
									"",
									"// Atualizar access token com o novo",
									"const newAccessToken = pm.response.headers.get('X-Access-Token');",
									"if (newAccessToken) {",
									"    pm.collectionVariables.set('accessToken', newAccessToken);",
									"    console.log('✅ Access Token atualizado:', newAccessToken.substring(0, 50) + '...');",
									"}"
								],
								"type": "text/javascript"
							}
