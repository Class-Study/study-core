								"exec": [
									"// Este é um teste de fluxo completo que será executado em sequência",
									"console.log('🔄 Executando fluxo completo de autenticação...');",
									"",
									"pm.test('Login successful', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Salvar tokens para os próximos passos",
									"const accessToken = pm.response.headers.get('X-Access-Token');",
									"const refreshToken = pm.response.headers.get('X-Refresh-Token');",
									"",
									"pm.collectionVariables.set('flowAccessToken', accessToken);",
									"pm.collectionVariables.set('flowRefreshToken', refreshToken);",
									"",
									"console.log('✅ Tokens salvos para fluxo completo');"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"teacher@example.com\",\n  \"password\": \"senha123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/login",
							"host": ["{{baseUrl}}"],
							"path": ["login"]
						}
					},
					"response": []
				}
			],
			"description": "Teste de fluxo completo: Login → Usar Token → Refresh → Logout"
		}
	]
