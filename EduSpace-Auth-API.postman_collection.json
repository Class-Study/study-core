		{
			"name": "4. Protected Endpoints",
			"item": [
				{
					"name": "4.1 Protected Endpoint with X-Access-Token",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Verificar se temos um access token disponível",
									"const accessToken = pm.collectionVariables.get('accessToken');",
									"if (!accessToken) {",
									"    console.log('⚠️ Access token não encontrado. Execute primeiro o login.');",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Este teste depende de ter um endpoint protegido configurado",
									"// Por enquanto, só verificamos se o token está sendo enviado",
									"pm.test('Access token is being sent', function () {",
									"    const accessToken = pm.request.headers.get('X-Access-Token');",
									"    pm.expect(accessToken).to.not.be.empty;",
									"});",
									"",
									"// Se o endpoint existir, deve retornar 200 ou 401/403",
									"if (pm.response.code !== 404) {",
									"    pm.test('Protected endpoint response', function () {",
									"        pm.expect([200, 401, 403]).to.include(pm.response.code);",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Access-Token",
								"value": "{{accessToken}}"
							}
						],
						"url": {
							"raw": "http://localhost:8080/api/v1/protected-endpoint",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["api", "v1", "protected-endpoint"]
						}
					},
					"response": []
				},
				{
					"name": "4.2 Protected Endpoint with Authorization Bearer",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Teste usando Authorization header como fallback",
									"pm.test('Authorization header is being sent', function () {",
									"    const authHeader = pm.request.headers.get('Authorization');",
									"    pm.expect(authHeader).to.include('Bearer');",
									"});",
									"",
									"if (pm.response.code !== 404) {",
									"    pm.test('Protected endpoint response with Bearer', function () {",
									"        pm.expect([200, 401, 403]).to.include(pm.response.code);",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
